# ============================
# MongoDB Configuration
# ============================
# Format: mongodb+srv://user:password@cluster.mongodb.net/dbname?...
# Special characters in password must be URL-encoded (e.g. @ -> %40)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ipfs-files?retryWrites=true&w=majority&appName=Cluster0

# ============================
# Django
# ============================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=your-random-secret-key-here
DEBUG=False

# ============================
# JWT Authentication
# ============================
# Any long random string — used to sign user tokens
JWT_SECRET=your-jwt-secret-here
# Optional: token lifetime in hours (default: 24)
# JWT_EXPIRY_HOURS=24

# ============================
# IPFS / Pinata
# ============================
# Get from https://app.pinata.cloud/keys (create an Admin key)
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_KEY=your-pinata-secret-key
# Optional: your dedicated Pinata gateway domain (no https:// prefix needed)
# PINATA_GATEWAY_URL=your-gateway.mypinata.cloud

# ============================
# CORS
# ============================
# URL of your React frontend
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated list of extra allowed origins
# CORS_EXTRA_ORIGINS=https://your-app.netlify.app,https://your-domain.com

# ============================
# Upload limits
# ============================
# Optional: max upload size in MB (default: 10)
# UPLOAD_LIMIT_MB=10
